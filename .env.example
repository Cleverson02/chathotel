# Chat Hotel — Variáveis de Ambiente

# Gmail Configuration
# Para usar Gmail, você precisa de uma "App Password" (não a senha normal da conta)
# Gere em: https://myaccount.google.com/apppasswords

# Email do Gmail que enviará os emails
EMAIL_USER=seu-email@gmail.com

# App Password do Gmail (não a senha normal da conta!)
# Gere em https://myaccount.google.com/apppasswords
EMAIL_PASS=sua-app-password

# Email de destino para receber as propostas
# Default: giu.debona@gmail.com
EMAIL_TO=giu.debona@gmail.com

# Node environment — production ou development
NODE_ENV=production
