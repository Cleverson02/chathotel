# Chat Hotel — Variáveis de Ambiente

# SendGrid API Key — Obter em: https://app.sendgrid.com/settings/api_keys
# Deixar vazio se não tiver conta SendGrid ainda (email não funcionará)
SENDGRID_API_KEY=SG.seu_api_key_aqui

# Email do remetente — será mostrado no "De:" do email
# Default: noreply@chathotel.elevare.tur.br
SENDER_EMAIL=noreply@chathotel.elevare.tur.br

# (Opcional) Email de destino para receber propostas
# Default: cleverson.s.silva@gmail.com
DESTINATION_EMAIL=cleverson.s.silva@gmail.com

# Node environment — production ou development
NODE_ENV=production
